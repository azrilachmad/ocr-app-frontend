# =============================================================================
# KnowledgeBase Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# These variables are used at BUILD TIME (Vite inlines them during build)
# =============================================================================

# Backend API URL (required)
# Development : http://localhost:3001/api
# Production  : https://api-ocr.synchro.co.id/api
VITE_API_BASE_URL=http://localhost:3001/api
