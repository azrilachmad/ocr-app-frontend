# =============================================================================
# KnowledgeBase Environment Variables — Production
# =============================================================================
# Copy this file to .env and fill in the values
# These variables are used at BUILD TIME (Vite inlines them during build)
# =============================================================================

# NOTE: KnowledgeBase uses '/api' as baseURL in its axios config.
# In production, nginx proxies /api/ requests to the Backend.
# No VITE_ env vars are required for the KnowledgeBase app.

# If you need to override the API URL (e.g., for a separate API domain),
# uncomment the line below and update the KnowledgeBase api.js service:
# VITE_API_BASE_URL=https://api.yourdomain.com/api
