# =============================================================================
# Frontend (OCR App) Environment Variables — Production
# =============================================================================
# Copy this file to .env and fill in the values
# These variables are used at BUILD TIME (Vite inlines them during build)
# =============================================================================

# Backend API URL
# Development : http://localhost:3001/api
# Production  : https://api.yourdomain.com/api  (separate API domain)
#             : https://ocr.yourdomain.com/api   (same domain via nginx proxy)
VITE_API_BASE_URL=https://api.yourdomain.com/api
