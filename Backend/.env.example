# =============================================================================
# Backend Environment Variables — Production
# =============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit the actual .env file to version control!
# =============================================================================

# Server Configuration
PORT=3001
NODE_ENV=production

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=synchro_scan
DB_USER=synchro_user
DB_PASS=CHANGE_ME_strong_db_password

# JWT Authentication
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# Cookie Configuration
# Use leading dot for cross-subdomain auth (e.g., .synchro.co.id)
# This allows cookies to be shared between ocr.domain.com and kb.domain.com
COOKIE_DOMAIN=.yourdomain.com

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=52428800

# CORS — Allowed Origins (comma-separated)
# Include ALL frontend domains that will access this API
ALLOWED_ORIGINS=https://ocr.yourdomain.com,https://kb.yourdomain.com

# Gemini AI API Key (optional — can also be configured per-user in Settings page)
# GEMINI_API_KEY=your_gemini_api_key_here
