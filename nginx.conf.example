# =============================================================================
# Synchro Scan - Nginx Configuration for Production (PM2 / Native)
# =============================================================================
# Domain-based virtual host setup
# Copy this file to: /etc/nginx/sites-available/synchro-scan
# Enable with: sudo ln -s /etc/nginx/sites-available/synchro-scan /etc/nginx/sites-enabled/
# Test config: sudo nginx -t
# Reload Nginx: sudo systemctl reload nginx
# =============================================================================

# Rate limiting zones
limit_req_zone $binary_remote_addr zone=api_limit:10m rate=10r/s;
limit_req_zone $binary_remote_addr zone=upload_limit:10m rate=2r/s;

# Upstream definitions
upstream backend {
    server 127.0.0.1:3001;
    keepalive 64;
}

upstream frontend {
    server 127.0.0.1:3004;
    keepalive 32;
}

upstream knowledgebase {
    server 127.0.0.1:3005;
    keepalive 32;
}

# =============================================
# HTTP → HTTPS redirect (all domains)
# =============================================
server {
    listen 80;
    listen [::]:80;
    server_name ocr.yourdomain.com kb.yourdomain.com api.yourdomain.com;

    # Let's Encrypt verification
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$server_name$request_uri;
    }
}

# =============================================
# Frontend — OCR Apps (ocr.yourdomain.com)
# =============================================
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name ocr.yourdomain.com;

    # SSL Configuration (managed by Certbot)
    ssl_certificate /etc/letsencrypt/live/ocr.yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/ocr.yourdomain.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_proxied any;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/json application/xml+rss;

    # Root for frontend
    root /var/www/synchro-scan/Frontend/dist;
    index index.html;

    # Frontend static files with caching
    location / {
        try_files $uri $uri/ /index.html;

        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    # API Proxy to Backend
    location /api/ {
        limit_req zone=api_limit burst=20 nodelay;

        # CORS headers at nginx level (ensures headers even on 502/503)
        add_header 'Access-Control-Allow-Origin' $http_origin always;
        add_header 'Access-Control-Allow-Credentials' 'true' always;
        add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, DELETE, PATCH, OPTIONS' always;
        add_header 'Access-Control-Allow-Headers' 'Content-Type, Authorization, X-Requested-With, Accept, Origin' always;
        add_header 'Access-Control-Expose-Headers' 'Set-Cookie' always;
        add_header 'Access-Control-Max-Age' '86400' always;

        # Handle preflight OPTIONS
        if ($request_method = 'OPTIONS') {
            return 204;
        }

        proxy_pass http://backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
    }

    # OCR endpoint with larger limits
    location /api/ocr/ {
        limit_req zone=upload_limit burst=5 nodelay;
        client_max_body_size 20M;

        # CORS headers
        add_header 'Access-Control-Allow-Origin' $http_origin always;
        add_header 'Access-Control-Allow-Credentials' 'true' always;
        add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, DELETE, PATCH, OPTIONS' always;
        add_header 'Access-Control-Allow-Headers' 'Content-Type, Authorization, X-Requested-With, Accept, Origin' always;

        if ($request_method = 'OPTIONS') {
            return 204;
        }

        proxy_pass http://backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 120s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }

    # Serve uploaded files
    location /uploads/ {
        alias /var/www/synchro-scan/Backend/uploads/;

        location ~* \.(jpg|jpeg|png|gif|webp|pdf)$ {
            expires 30d;
            add_header Cache-Control "public";
            add_header X-Content-Type-Options "nosniff" always;
        }

        location ~ \. {
            deny all;
        }
    }

    # Health check
    location /health {
        proxy_pass http://backend/api/health;
        proxy_http_version 1.1;
    }

    # Deny hidden files
    location ~ /\. {
        deny all;
    }
}

# =============================================
# KnowledgeBase (kb.yourdomain.com)
# =============================================
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name kb.yourdomain.com;

    ssl_certificate /etc/letsencrypt/live/kb.yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/kb.yourdomain.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_proxied any;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/json application/xml+rss;

    root /var/www/synchro-scan/KnowledgeBase/dist;
    index index.html;

    # KnowledgeBase SPA routing
    location / {
        try_files $uri $uri/ /index.html;

        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    # API Proxy to Backend (same backend serves KB APIs)
    location /api/ {
        limit_req zone=api_limit burst=20 nodelay;

        proxy_pass http://backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    location ~ /\. {
        deny all;
    }
}

